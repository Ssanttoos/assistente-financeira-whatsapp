# ─── Firebase ─────────────────────────────────────────────────────────────────
# Caminho para o arquivo JSON de credenciais do Firebase (Service Account)
FIREBASE_CREDENTIALS_PATH=config/firebase-credentials.json
FIREBASE_PROJECT_ID=seu-projeto-firebase

# ─── Evolution API ─────────────────────────────────────────────────────────────
# URL da sua instância da Evolution API (ex: https://sua-evolution.onrender.com)
EVOLUTION_API_URL=https://sua-evolution-api.com
# Chave de API da Evolution
EVOLUTION_API_KEY=sua-chave-aqui
# Nome da instância WhatsApp configurada na Evolution
EVOLUTION_INSTANCE_NAME=assistente

# ─── Aplicação ─────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ─── OpenAI (opcional - para NLP mais avançado no futuro) ─────────────────────
OPENAI_API_KEY=
